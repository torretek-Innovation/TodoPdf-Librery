{
  "name": "todo-pdf",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "author": "TorreTek",
  "description": "TodoPDF Library - Gestor de PDFs inteligente",
  "scripts": {
    "dev": "next dev --turbo",
    "dev:webpack": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "concurrently -k \"cross-env BROWSER=none npm run dev\" \"wait-on http://localhost:3000 && cross-env ELECTRON_START_URL=http://localhost:3000 electron .\"",
    "electron:build": "npm run build && node scripts/prepare-electron-build.js && electron-builder"
  },
  "build": {
    "appId": "com.torretek.todopdf",
    "productName": "TodoPDF Library",
    "afterPack": "./scripts/finalize-build.js",
    "directories": {
      "output": "release"
    },
    "asar": false,
    "files": [
      "electron/**/*",
      "public/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "electron-dist",
        "to": "standalone",
        "filter": [
          "**/*",
          "node_modules/**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/logo/only_logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "dependencies": {
    "@prisma/client": "^6.19.1",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.26.2",
    "idb": "^8.0.3",
    "js-cookie": "^3.0.5",
    "jsonwebtoken": "^9.0.3",
    "next": "16.1.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.4.530",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.5.0",
    "react-pdf": "^10.3.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/js-cookie": "^3.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "postcss": "^8.5.6",
    "prisma": "^6.19.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5",
    "wait-on": "^9.0.3"
  }
}