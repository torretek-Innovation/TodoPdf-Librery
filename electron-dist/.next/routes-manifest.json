      "page": "/api/assets/[...path]",
      "regex": "^/api/assets/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPpath": "nxtPpath"
      },
      "namedRegex": "^/api/assets/(?<nxtPpath>.+?)(?:/)?$"
    },
    {
      "page": "/api/external-libraries/[id]",
      "regex": "^/api/external\\-libraries/([^/]+?)(?:/)?$",
